# ============================================================
# Oskín — Unified Environment Configuration
# Copy to .env and fill in production values
# ============================================================

# --- PostgreSQL ---
POSTGRES_USER=oskin
POSTGRES_PASSWORD=oskin_pass
POSTGRES_DB=oskin_db
POSTGRES_PORT=5432

# --- Backend ---
DATABASE_URL=postgresql://oskin:oskin_pass@db:5432/oskin_db
SECRET_KEY=change_me_in_production_use_openssl_rand_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
BACKEND_PORT=8000

# Base URL used by Flutter (passed via --dart-define=BACKEND_URL)
# For Android emulator: http://10.0.2.2:8000
# For iOS simulator:    http://localhost:8000

# --- Model ---
MODEL_PATH=/app/ml_models/plant_disease.tflite
MODEL_CLASS_NAMES_PATH=/app/ml_models/class_names.txt
MODEL_VERSION=1.0.0
IMAGE_SIZE=224

# --- Logging ---
LOG_LEVEL=INFO

# --- Adminer (optional DB UI, run with: docker compose --profile tools up) ---
ADMINER_PORT=8080


GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY